# Core (required)
GOOGLE_API_KEY=your_google_api_key

# Optional
ADK_DEBUG=false
LLM_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────────────────────
# Platform credentials — all optional.
# Set the ones you want to auto-publish to.
# Platforms without credentials are drafted and copyable,
# but not auto-published.
# ─────────────────────────────────────────────────────────────

# LinkedIn
LINKEDIN_ACCESS_TOKEN=

# X / Twitter (all 4 required together)
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Bluesky (both required together)
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=

# Threads / Meta (both required together)
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# WhatsApp Cloud API (both required together)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Mastodon (both required together)
MASTODON_ACCESS_TOKEN=
MASTODON_INSTANCE_URL=

# Telegram channel (both required together)
# TELEGRAM_CHAT_ID = your channel, e.g. "@mychannel" or "-1001234567890"
# The bot must be an admin of the channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
